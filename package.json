{
  "name": "velmont-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Velmont Design Studio — commercial interior contracting website",
  "scripts": {
    "dev": "npm run copy-components && vite",
    "build": "npm run copy-components && npm run optimize-images && vite build",
    "preview": "vite preview --port 5173",
    "preview:ci": "vite preview --port 5173",
    "copy-components": "node scripts/copy-components.js",
    "optimize-images": "node scripts/convert-images.js",
    "lint": "eslint \"src/**/*.{js,mjs}\" \"scripts/**/*.js\" \"__tests__/**/*.js\" \"e2e/**/*.js\"",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\" \"scripts/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "lighthouse": "lhci autorun"
  },
  "devDependencies": {
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.45.0",
    "eslint": "^8.57.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.0",
    "sharp": "^0.33.4",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
